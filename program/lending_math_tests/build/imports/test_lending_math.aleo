program test_lending_math.aleo;

closure mirror_weighted_collateral_usd:
    input r0 as u64;
    input r1 as u64;
    input r2 as u64;
    cast r0 into r3 as u128;
    cast r1 into r4 as u128;
    mul r3 r4 into r5;
    cast r2 into r6 as u128;
    cast 1000000u64 into r7 as u128;
    cast 10000u64 into r8 as u128;
    mul r7 r8 into r9;
    is.eq r6 0u128 into r10;
    div 340282366920938463463374607431768211455u128 r6 into r11;
    lte r5 r11 into r12;
    or r10 r12 into r13;
    mul r5 r6 into r14;
    div r14 r9 into r15;
    cast r15 into r16 as u64;
    cast 1000000u64 into r17 as u128;
    div r5 r17 into r18;
    mul r18 r6 into r19;
    cast 10000u64 into r20 as u128;
    div r19 r20 into r21;
    cast r21 into r22 as u64;
    ternary r13 r16 r22 into r23;
    output r23 as u64;

function test_weighted_known:
    call mirror_weighted_collateral_usd 10000000u64 1000000u64 7500u64 into r0;
    is.eq r0 7500000u64 into r1;
    assert.eq r1 true;

closure debt_usd_micro:
    input r0 as u64;
    input r1 as u64;
    cast r0 into r2 as u128;
    cast r1 into r3 as u128;
    mul r2 r3 into r4;
    cast 1000000u64 into r5 as u128;
    div r4 r5 into r6;
    cast r6 into r7 as u64;
    output r7 as u64;

function test_health_cross_ok:
    call mirror_weighted_collateral_usd 20000000u64 1000000u64 7500u64 into r0;
    call mirror_weighted_collateral_usd 10000000u64 1000000u64 8500u64 into r1;
    call mirror_weighted_collateral_usd 0u64 1000000u64 8500u64 into r2;
    cast r0 into r3 as u128;
    cast r1 into r4 as u128;
    add r3 r4 into r5;
    cast r2 into r6 as u128;
    add r5 r6 into r7;
    call debt_usd_micro 0u64 1000000u64 into r8;
    call debt_usd_micro 0u64 1000000u64 into r9;
    call debt_usd_micro 0u64 1000000u64 into r10;
    cast r8 into r11 as u128;
    cast r9 into r12 as u128;
    add r11 r12 into r13;
    cast r10 into r14 as u128;
    add r13 r14 into r15;
    cast 10000000u64 into r16 as u128;
    cast 1000000u64 into r17 as u128;
    mul r16 r17 into r18;
    cast 1000000u64 into r19 as u128;
    div r18 r19 into r20;
    cast r20 into r21 as u64;
    cast r21 into r22 as u128;
    add r15 r22 into r23;
    lte r23 r7 into r24;
    assert.eq r24 true;

function test_health_over_fail:
    call mirror_weighted_collateral_usd 1000000u64 1000000u64 7500u64 into r0;
    cast r0 into r1 as u128;
    cast 1000000u64 into r2 as u128;
    add 0u128 r2 into r3;
    lte r3 r1 into r4;
    not r4 into r5;
    assert.eq r5 true;

function test_wd_xa_rem_log:
    cast 1000000u64 into r0 as u128;
    cast 42596u64 into r1 as u128;
    mul r0 r1 into r2;
    cast 1000000u64 into r3 as u128;
    div r2 r3 into r4;
    cast r4 into r5 as u64;
    cast 0u64 into r6 as u128;
    cast 1000000u64 into r7 as u128;
    mul r6 r7 into r8;
    cast 1000000u64 into r9 as u128;
    div r8 r9 into r10;
    cast r10 into r11 as u64;
    cast 0u64 into r12 as u128;
    cast 1000000u64 into r13 as u128;
    mul r12 r13 into r14;
    cast 1000000u64 into r15 as u128;
    div r14 r15 into r16;
    cast r16 into r17 as u64;
    cast r5 into r18 as u128;
    cast r11 into r19 as u128;
    add r18 r19 into r20;
    cast r17 into r21 as u128;
    add r20 r21 into r22;
    cast 40000u64 into r23 as u128;
    cast 1000000u64 into r24 as u128;
    mul r23 r24 into r25;
    cast 1000000u64 into r26 as u128;
    div r25 r26 into r27;
    cast r27 into r28 as u64;
    gt r28 0u64 into r29;
    assert.eq r29 true;
    cast r28 into r30 as u128;
    lte r30 r22 into r31;
    assert.eq r31 true;
    gt r28 r5 into r32;
    ternary r32 r5 r28 into r33;
    cast r33 into r34 as u128;
    cast 1000000u64 into r35 as u128;
    mul r34 r35 into r36;
    cast 42596u64 into r37 as u128;
    div r36 r37 into r38;
    cast r38 into r39 as u64;
    gt r39 1000000u64 into r40;
    ternary r40 1000000u64 r39 into r41;
    cast r41 into r42 as u128;
    cast 42596u64 into r43 as u128;
    mul r42 r43 into r44;
    cast 1000000u64 into r45 as u128;
    div r44 r45 into r46;
    cast r46 into r47 as u64;
    gt r28 r47 into r48;
    sub r28 r47 into r49;
    ternary r48 r49 0u64 into r50;
    gt r50 r11 into r51;
    ternary r51 r11 r50 into r52;
    cast r52 into r53 as u128;
    cast 1000000u64 into r54 as u128;
    mul r53 r54 into r55;
    cast 1000000u64 into r56 as u128;
    div r55 r56 into r57;
    cast r57 into r58 as u64;
    gt r58 0u64 into r59;
    ternary r59 0u64 r58 into r60;
    cast r60 into r61 as u128;
    cast 1000000u64 into r62 as u128;
    mul r61 r62 into r63;
    cast 1000000u64 into r64 as u128;
    div r63 r64 into r65;
    cast r65 into r66 as u64;
    gt r50 r66 into r67;
    sub r50 r66 into r68;
    ternary r67 r68 0u64 into r69;
    gt r69 r17 into r70;
    ternary r70 r17 r69 into r71;
    cast r71 into r72 as u128;
    cast 1000000u64 into r73 as u128;
    mul r72 r73 into r74;
    cast 1000000u64 into r75 as u128;
    div r74 r75 into r76;
    cast r76 into r77 as u64;
    gt r77 0u64 into r78;
    ternary r78 0u64 r77 into r79;
    cast r79 into r80 as u128;
    cast 1000000u64 into r81 as u128;
    mul r80 r81 into r82;
    cast 1000000u64 into r83 as u128;
    div r82 r83 into r84;
    cast r84 into r85 as u64;
    gt r69 r85 into r86;
    sub r69 r85 into r87;
    ternary r86 r87 0u64 into r88;
    is.eq r88 1u64 into r89;
    assert.eq r89 true;
    lte r88 3u64 into r90;
    assert.eq r90 true;

constructor:
    assert.eq edition 0u16;
